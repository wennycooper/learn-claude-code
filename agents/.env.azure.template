# Azure OpenAI Configuration
# 请填入您的 Azure OpenAI 配置信息

# Azure OpenAI Endpoint (格式: https://your-resource-name.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Azure OpenAI API Key
AZURE_OPENAI_API_KEY=your-api-key-here

# Azure OpenAI API Version (推荐使用 2024-02-15-preview 或更新版本)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI Deployment Name (您在 Azure 中创建的 GPT-4o 部署名称)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# 使用说明:
# 1. 复制此文件并重命名为 .env
# 2. 填入您的实际配置信息
# 3. 确保 .env 文件在 .gitignore 中，避免泄露密钥
